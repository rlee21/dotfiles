{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "allow",

    "read": {
      "*": "allow",
      "**/config/application.yml": "deny",
      "~/.zshrc": "deny",
      "~/.bashrc": "deny",
      "~/.ssh/**": "deny",
      "~/.aws/**": "deny",
      "./.git/**": "deny",
      "**/*.env": "deny",
      "**/*.cert": "deny",
      "**/*.crt": "deny",
      "**/*.key": "deny",
      "**/*.pem": "deny",
      "**/*.gpg": "deny",
      "**/*.pgp": "deny"
    },

    "bash": {
      "*": "ask",
      "git *": "allow",
      "npm *": "allow",
      "pnpm *": "allow",
      "yarn *": "allow",
      "make *": "allow",
      "cargo *": "allow",

      "rm *": "deny",
      "del *": "deny",
      "rmdir *": "deny",
      "unlink *": "deny",
      "sudo *": "deny",
      "ftp *": "deny",
      "sftp *": "deny",
      "scp *": "deny",
      "ssh *": "deny",
      "git config --global *": "deny",
      "git branch -d *": "deny",
      "git branch -D *": "deny",
      "git push --force *": "deny",
      "git tag -d *": "deny",
      "git stash drop *": "deny",
      "git stash clear *": "deny",
      "git remote add *": "deny",
      "git remote remove *": "deny",
      "git remote set-url *": "deny"
    }
  },

  "mcp": {
    "atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": true
    }
  }
}
